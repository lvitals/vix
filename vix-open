#!/bin/sh
set -e

# Later, we're going to want to set $IFS to a single newline, so let's prepare one.
NL='
'

fatal() {
	echo "$@" >&2
	exit 1
}

usage() {
	fatal "Usage: $(basename "$0") [-f] [-p prompt] [-s] [--] [file-pattern]

Interactively select a file to open

Options:
    -f            always present given arguments, even when there is only one
    -p            use prompt as prompt string
    -s            internal: indicate the item was explicitly selected from a menu
    file-pattern  list of filenames and directories"
}

# print a list of filenames on stdin and distinguish directories
wrap_dirs() {
	while read -r filename
	do
		if [ -z "$filename" ]; then continue; fi
		# Remove trailing slash for directory check if present
		clean_name="${filename%/}"
		if [ -d "$clean_name" ]; then
			printf '%s/\n' "$clean_name"
		else
			printf '%s\n' "$clean_name"
		fi
	done
}

VIX_OPEN_LINES="${VIX_OPEN_LINES:-0}"
VIX_MENU_PROMPT=''
IS_SELECTED=''

while getopts fhp:s opt; do
	case "$opt" in
	f)
		# Legacy flag, now mostly handled by logic
		;;
	p)
		VIX_MENU_PROMPT="$OPTARG"
		;;
	s)
		IS_SELECTED='1'
		;;
	*)
		usage
		;;
	esac
done
shift "$((OPTIND - 1))"

# If we have a single argument, check if it's a directory or a selected file
if [ "$#" -eq 1 ]; then
	if [ -d "$1" ]; then
		# It's a directory: always expand and show its contents in a menu
		cd "$1"
		IFS="$NL"
		# Recursively call without -s to show the menu for the new directory
		exec "$0" -p "$VIX_MENU_PROMPT" -- "$(ls -1)"
		exit 0
	elif [ "$IS_SELECTED" = '1' ]; then
		# User explicitly picked this file from the menu!
		# Return absolute path and exit.
		filename="${1%/}" # strip trailing slash if directory-style
		parentdir="$(dirname -- "$filename")"
		if [ -d "$parentdir" ]; then
			cd "$parentdir"
			printf '%s/%s\n' "$(pwd -P)" "$(basename -- "$filename")"
			exit 0
		else
			# Fallback for non-existent files typed by user
			printf '%s\n' "$1"
			exit 0
		fi
	fi
	# If it's a file but NOT selected (initial glob match), fall through to show menu
fi

# At this point, we show the menu to the user.
# We include ".." for navigation and all arguments passed.
CHOICE="$(printf '%s\n' '..' "$@" | wrap_dirs | vix-menu -b -l "$VIX_OPEN_LINES" -p "$VIX_MENU_PROMPT")"

if [ -z "$CHOICE" ]; then
	exit 1
fi

# Recurse with -s to indicate that this item was explicitly chosen
exec "$0" -p "$VIX_MENU_PROMPT" -s -- "$CHOICE"
